<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.example.pixelfluidsimulation.PixelFluidView
        android:id="@+id/fluidView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:padding="16dp"
        android:weightSum="10">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/checkParticle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Render Particles"
                android:textSize="12sp"
                android:textColor="#FFF"
                android:buttonTint="#FFF" />

            <CheckBox
                android:id="@+id/checkPixel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Render Pixels"
                android:textSize="12sp"
                android:textColor="#FFF"
                android:buttonTint="#FFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/checkGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Grid"
                android:textSize="12sp"
                android:textColor="#FFF"
                android:buttonTint="#FFF" />

            <CheckBox
                android:id="@+id/checkFPS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show FPS"
                android:textSize="12sp"
                android:textColor="#FFF"
                android:buttonTint="#FFF" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Density Stiffness"
                    android:textSize="12sp"
                    android:textColor="#FFF" />
                <TextView
                    android:id="@+id/txtStiffnessValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFF" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seekStiffness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensor Strength"
                    android:textSize="12sp"
                    android:textColor="#FFF" />
                <TextView
                    android:id="@+id/txtSensorValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFF" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seekSensor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>